{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/autoessa-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://www.autoessabackend.somee.com/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
